DATABASE_URL="postgresql://postgres:123456@localhost:5432/document_db"
# ========================
# Auth Service Environment
# ========================

# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=123456
DB_NAME=document_db

# JWT
JWT_ACCESS_SECRET=JUSTASECRET
JWT_REFRESH_SECRET=JWT_ACCESS_SECRET=JUSTASECRET
JWT_ACCESS_EXPIRES_IN=3d    
JWT_REFRESH_EXPIRES_IN=7d
