generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Summary {
  id          String   @id @default(uuid()) @db.Uuid
  documentId  String   @map("document_id") @db.Uuid
  content     String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([documentId])
  @@map("summaries")
}
